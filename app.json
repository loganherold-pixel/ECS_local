{
  "expo": {
    "name": "Expedition Planner Elite",
    "slug": "planning-offline-sync",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "planning-offline-sync",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "ECS uses Bluetooth to connect to your vehicle power systems for live telemetry.",
        "NSLocationWhenInUseUsageDescription": "ECS uses your location for live navigation, expedition tracking, and route intelligence.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "ECS uses your location for live expedition tracking, route awareness, and navigation."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0B0E12"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION"
      ],
      "package": "com.expeditioncommand.planningofflinesync"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0B0E12"
        }
      ],
      [
        "expo-navigation-bar",
        {
          "visibility": "hidden",
          "barStyle": "light"
        }
      ],
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "modes": [],
          "bluetoothAlwaysPermission": "ECS uses Bluetooth to connect to your vehicle power systems for live telemetry."
        }
      ],
      "./plugins/android-auto/withAndroidAuto",
      "./plugins/carplay/withCarPlay",
      "expo-secure-store",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cd718e96-3084-4d2b-ae06-d1b5bd187071"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/cd718e96-3084-4d2b-ae06-d1b5bd187071"
    }
  }
}
