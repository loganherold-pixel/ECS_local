EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
EXPO_PUBLIC_MAPBOX_TOKEN=your-mapbox-token

# CampOps internal beta
# Keep disabled for normal production/public behavior. Enables deterministic CampOps
# route pins and Camp Intel only for controlled internal beta builds/sessions.
EXPO_PUBLIC_ENABLE_CAMPOPS_INTERNAL_BETA=false

# Internal/dev-only Navigate overlay using local sample polygons.
# Keep disabled for normal production/public behavior until real provider QA is complete.
EXPO_PUBLIC_ECS_DISPERSED_CAMPING_LAYER=false

# Internal/dev-only Navigate overlay using local sample established campground points.
# Keep disabled until approved campground data ingestion is validated on Android.
EXPO_PUBLIC_ECS_ESTABLISHED_CAMPSITES_LAYER=false

# Optional verbose camp-layer lifecycle logs for local debugging only.
# Actual fetch failures still emit sanitized diagnostics without this flag.
EXPO_PUBLIC_ECS_CAMP_LAYER_DEBUG=0

# ECS 5.0 provider configuration
# Keep real API keys in your local .env or deployment secret store only.
OPENWEATHER_API_KEY=your-openweather-api-key
ENABLE_OPENWEATHER=true
ENABLE_OPENWEATHER_ONECALL=true

ENABLE_OPENWEATHER_ROAD_RISK=false
ENABLE_OPENWEATHER_AIR_POLLUTION=false
ENABLE_OPENWEATHER_FIRE_INDEX=false
REQUIRE_OPENWEATHER_ROAD_RISK=false
REQUIRE_OPENWEATHER_AIR_POLLUTION=false
REQUIRE_OPENWEATHER_FIRE_INDEX=false

NWS_USER_AGENT=admin@example.com
ENABLE_NWS=true

AIRNOW_API_KEY=your-airnow-api-key
ENABLE_AIRNOW=true

NASA_FIRMS_MAP_KEY=your-nasa-firms-map-key
ENABLE_NASA_FIRMS=true

ENABLE_NIFC_WFIGS=true
ENABLE_INCIWEB=true

ENABLE_USFS_MVUM=true
ENABLE_BLM_PLAD=true

NPS_API_KEY=your-nps-api-key
ENABLE_NPS=true

# Camp layer Edge Functions
# These are server-side Supabase Edge Function secrets/config. Keep real values
# in Supabase function secrets or a local-only .env, never in client code.
ECS_SUPABASE_URL=https://your-project.supabase.co
ECS_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
PAD_US_MANAGER_FEATURE_URL=https://services.arcgis.com/v01gqwM5QqNysAAi/arcgis/rest/services/Manager_Name/FeatureServer/0/query
ECS_EDGE_USER_AGENT=ECS camp layer diagnostics (admin@example.com)
RIDB_API_KEY=your-ridb-api-key
CAMPFLARE_API_KEY=your-campflare-api-key
ACTIVE_API_KEY=your-active-api-key
ACTIVE_API_SECRET=your-active-api-secret
RESERVEAMERICA_API_KEY=your-reserveamerica-api-key
ASPIRA_API_KEY=your-aspira-api-key
OSM_USER_AGENT=ECS campground search (admin@example.com)
OSM_ATTRIBUTION=OpenStreetMap contributors
OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter

ENABLE_STATE_DOT_511=false
STATE_DOT_511_PROVIDER=511 SF Bay
STATE_DOT_511_API_KEY=your-state-dot-511-api-key
STATE_DOT_511_BASE_URL=https://example.invalid/traffic/events

ENABLE_STATE_FIRE_AGENCY=false
STATE_FIRE_AGENCY_PROVIDER=
STATE_FIRE_AGENCY_API_KEY=
STATE_FIRE_AGENCY_BASE_URL=

ENABLE_COUNTY_EMERGENCY_FEEDS=false
COUNTY_EMERGENCY_PROVIDER=
COUNTY_EMERGENCY_API_KEY=
COUNTY_EMERGENCY_BASE_URL=

ENABLE_MANUAL_AGENCY_INGESTION=true

# Garmin/inReach MapShare/KML integration
# Read-only and disabled by default. Do not place Garmin secrets in client-visible env vars.
GARMIN_INREACH_ENABLED=false
GARMIN_INREACH_MODE=off
GARMIN_INREACH_KML_FEEDS=
GARMIN_INREACH_MAPSHARE_POLL_INTERVAL_SECONDS=300
GARMIN_INREACH_MAPSHARE_STALE_AFTER_MINUTES=30
GARMIN_INREACH_DEMO_KML_ENABLED=false
GARMIN_INREACH_LOG_PII=false
